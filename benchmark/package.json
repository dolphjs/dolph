{
    "name": "dolph-benchmark",
    "version": "1.0.0",
    "description": "Performance benchmarks: dolphjs vs Express, NestJS (Express), NestJS (Fastify), Hono",
    "private": true,
    "scripts": {
        "bench": "node runner.js",
        "bench:quick": "node runner.js --quick",
        "bench:dolph": "node runner.js --only dolph",
        "bench:express": "node runner.js --only express",
        "bench:hono": "node runner.js --only hono",
        "bench:nest-express": "node runner.js --only nest-express",
        "bench:nest-fastify": "node runner.js --only nest-fastify",
        "bench:files": "node file-runner.js",
        "bench:files:quick": "node file-runner.js --quick",
        "bench:files:dolph": "node file-runner.js --only dolph",
        "bench:files:express": "node file-runner.js --only express+multer",
        "bench:files:nest-express": "node file-runner.js --only nest-express",
        "bench:files:nest-fastify": "node file-runner.js --only nest-fastify"
    },
    "dependencies": {
        "@fastify/multipart": "^8.3.0",
        "@hono/node-server": "^1.13.0",
        "@nestjs/common": "^10.4.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-fastify": "^10.4.0",
        "express": "^4.18.2",
        "fastify": "^4.28.0",
        "hono": "^4.6.0",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.0",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.5"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^20.3.2"
    }
}
